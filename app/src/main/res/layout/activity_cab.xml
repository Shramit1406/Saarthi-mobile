<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <!-- Map View (100% Screen) -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- SOS Button above mesh panel -->
    <androidx.cardview.widget.CardView
        android:id="@+id/sosButton"
        android:layout_width="72dp"
        android:layout_height="72dp"
        app:cardCornerRadius="36dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F44336"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:layout_marginBottom="12dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toTopOf="@id/meshNetworkPanel"
        app:layout_constraintEnd_toEndOf="parent">
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="SOS"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>
    </androidx.cardview.widget.CardView>
    
    <!-- Bottom Taskbar (Mesh Status & Controls) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/meshNetworkPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="16dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            
            <!-- Mesh Header -->
            <TextView
                android:id="@+id/meshNetworkHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 MESH NETWORK • NO INTERNET NEEDED"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp"/>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/userId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USER_ABC123"
                        android:textColor="#333"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:id="@+id/meshPeerCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 peer(s) connected"
                        android:textColor="#666"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">
                    
                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ready • Mesh relay"
                        android:textColor="#4CAF50"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:id="@+id/meshStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏳ Initializing mesh..."
                        android:textColor="#FF9800"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="12dp"/>
                
            <!-- Police Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/policeCount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scanning for police nodes..."
                    android:textColor="#333"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/policeStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔄 SOS will relay"
                    android:textColor="#FF9800"
                    android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>
            
            <!-- Hidden original elements kept so code doesn't crash -->
            <TextView
                android:id="@+id/meshInfoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
            <TextView
                android:id="@+id/userType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    
</androidx.constraintlayout.widget.ConstraintLayout>
